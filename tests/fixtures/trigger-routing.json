        {
          "id": "code-combined-positive",
          "mode": "positive",
          "prompt": "Review and grade this PR in one pass with findings and an A-F verdict.",
          "expected": "suede-code"
        },
        {
          "id": "code-ambiguous-fallback",
          "mode": "ambiguous",
          "prompt": "Check this PR and tell me if it ships.",
          "expected": "suede-code"
        }
      ]
